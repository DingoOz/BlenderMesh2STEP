# Python
__pycache__/
*.py[cod]
*.egg-info/

# Build / release artifacts
/dist/

# Local OCCT test virtualenv / target install (kernel-path tests; not shipped)
/.occ-venv/
/.occ-blender/

# Test outputs
*.step
*.stp
*.pmi.json
*.pmi.csv

# Editor / OS
.DS_Store
.idea/
.vscode/

# LaTeX build artifacts (docs/)
docs/*.aux
docs/*.log
docs/*.out
docs/*.toc
docs/*.fls
docs/*.fdb_latexmk
docs/*.synctex.gz

# Example STEP deliverables are tracked (test-output .step elsewhere is not)
!examples/*.step
!examples/*.stp
